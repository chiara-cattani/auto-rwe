  "narrative": [
    {
      "title": "Headline",
      "content": "Robust digestive health benefit demonstrated in 4 of 5 RCTs. High-baseline subjects show 60–80% stronger treatment response — a clear precision targeting opportunity."
    },
    {
      "title": "Executive Summary",
      "content": "Analysis of 5 RCTs (N=450) demonstrates consistent improvement in Gut Comfort Score with Danone probiotic formulations. Four studies reached statistical significance (p<0.05), with a pooled effect of Cohen's d = –0.54 (95% CI: –0.66 to –0.42). The single non-significant result (Activia Light, Japan) involved a low-baseline cohort (mean score 44.2 vs >60 in other studies), limiting both clinical relevance and statistical power."
    },
    {
      "title": "Subgroup Opportunity",
      "content": "Subjects with high baseline gut discomfort show a 60–80% stronger treatment response (pooled d ≈ –0.90) compared to normal-baseline subjects (d ≈ –0.47). This difference is consistent across all 5 studies and represents a clear opportunity for targeted consumer positioning and precision marketing of Activia and Actimel probiotic ranges."
    },
    {
      "title": "Studies Included",
      "content": "activia_eu_01: Activia Probiotic, EU, Adults 18–65, n=80, Phase III — d=–0.72 (p<0.001) | actimel_asia_02: Actimel Daily, Asia, Adults 18–65, n=100, Phase III — d=–0.58 (p=0.001) | danone_elderly_03: Actimel Senior, EU, Adults 65+, n=60, Phase II — d=–0.61 (p=0.003) | activia_us_04: Activia Probiotic, US, Adults 18–65, n=120, Phase III — d=–0.69 (p<0.001) | activia_japan_05: Activia Light, Japan, Adults 18–65, n=90, Phase II — d=–0.18 (p=0.24, not significant)"
    },
    {
      "title": "Confidence Assessment",
      "content": "HIGH — 4/5 studies significant with consistent direction. Three Phase III trials provide strong regulatory-grade evidence. The Japan result is explained by low baseline severity (floor effect), not product failure. Inter-study consistency is excellent (I² estimated <30%)."
    },
    {
      "title": "Strategic Implication",
      "content": "Activia and Actimel probiotics demonstrate clinically meaningful gut comfort benefit, particularly in adults with moderate-to-high baseline discomfort. Recommend prioritizing 'high-discomfort consumer' targeting in marketing campaigns. Consider a dedicated Japan Phase III study using high-baseline screening criteria to close the evidence gap."
    }
  ]
